{
  "name": "custom-domain-tracking",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "predeploy": "npx tsx scripts/predeploy.ts",
    "deploy": "npm run predeploy && wrangler deploy",
    "setup-secrets": "npx tsx scripts/setup-secrets.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20240925.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.3",
    "wrangler": "^4.80.0"
  }
}
